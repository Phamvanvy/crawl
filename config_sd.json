{
  "detector": {
    "detector": "ctd",
    "detection_size": 2560,
    "box_threshold": 0.25,
    "unclip_ratio": 2.6,
    "det_invert": false,
    "det_gamma_correct": false,
    "det_rotate": false,
    "det_auto_rotate": false
  },
  "ocr": {
    "ocr": "48px",
    "min_text_length": 0,
    "ignore_bubble": 0,
    "use_mocr_merge": true
  },
  "inpainter": {
    "inpainter": "manga_sd_cn",
    "inpainting_size": 768,
    "inpainting_precision": "fp16"
  },
  "mask_dilation_offset": 18,
  "render": {
    "renderer": "default",
    "alignment": "auto",
    "direction": "auto",
    "font_size_offset": 0,
    "font_size_minimum": 14,
    "disable_font_border": false,
    "no_hyphenation": false
  }
}
